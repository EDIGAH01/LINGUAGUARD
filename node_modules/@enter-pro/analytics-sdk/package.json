{
  "name": "@enter-pro/analytics-sdk",
  "version": "0.0.10",
  "type": "module",
  "private": false,
  "description": "Standalone analytics SDK for Enter-generated websites",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "keywords": [
    "analytics",
    "tracking",
    "website",
    "enter",
    "sdk"
  ],
  "devDependencies": {
    "@types/node": "^20.19.9",
    "eslint": "^9.39.1",
    "happy-dom": "^15.11.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "@workspace/eslint-config": "0.0.0",
    "@workspace/typescript-config": "0.0.0"
  },
  "peerDependencies": {
    "web-vitals": "^4.2.4"
  },
  "peerDependenciesMeta": {
    "web-vitals": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest --run"
  }
}